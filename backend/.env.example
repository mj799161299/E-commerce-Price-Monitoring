# 应用配置
APP_NAME=电商价格监控系统
APP_VERSION=1.0.0
DEBUG=False

# 数据库配置
DATABASE_URL=postgresql+asyncpg://price_monitor:your_password@db:5432/price_monitor

# JWT配置
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AES加密密钥（必须是32字节）
AES_KEY=your-aes-key-32-bytes-long-key!

# CORS配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost"]

# API限流配置
RATE_LIMIT_PER_MINUTE=60
